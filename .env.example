# Local / cloud configuration example
# Copy this file to .env locally if needed. Do not commit .env.

# Access codes
QUIZ_LEARNER_CODE=MONCODE2026
QUIZ_TRAINER_PASSWORD=MonMotDePasseFort

# Database mode for future cloud version
# sqlite = current local prototype
# postgres = future Supabase/PostgreSQL mode
APP_DATABASE_MODE=sqlite

# Local SQLite database path
SQLITE_DB_PATH=data/quiz_history.db

# Supabase / PostgreSQL connection string for future deployment
# Example format:
# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional public app URL after deployment
PUBLIC_APP_URL=
